# ============================================================================
# Bobthebuilder environment configuration
# Copy to .env (local) or set as secrets (fly.io / prod).
# ============================================================================

# --- Required ---------------------------------------------------------------

# Postgres connection string.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Polygon.io API key for market data / options snapshots.
POLYGON_API_KEY=

# Alpaca brokerage credentials (paper or live).
ALPACA_API_KEY=
ALPACA_API_SECRET=


# --- Trading safety gates ---------------------------------------------------

# Base URL for the Alpaca REST API. Defaults to the paper endpoint.
# Set to https://api.alpaca.markets ONLY if you also set ALLOW_LIVE_TRADING=true.
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets

# Must be exactly "true" to allow AlpacaService to boot against a non-paper URL.
# Leave unset (or any other value) to enforce paper-only trading.
# ALLOW_LIVE_TRADING=

# Hard floor on account equity before the loop places any new orders.
MIN_REQUIRED_EQUITY=2000

# Daily loss circuit breaker (fraction of last_equity). 0.03 = 3%.
MAX_DAILY_LOSS_PCT=0.03

# Portfolio-level kill switch thresholds (from latest risk_metrics row).
KILL_SWITCH_MAX_CONCENTRATION=0.4
KILL_SWITCH_MAX_HEAT=0.25


# --- Agent debate (optional) ------------------------------------------------

# If unset, agent LLM calls fall back to AbacusAI (see below).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Enables agent debate in the analysis pipeline. Unset or "false" disables.
# AGENT_DEBATE_ENABLED=true

# Legacy AbacusAI gateway — fallback when ANTHROPIC_API_KEY is not set.
# ABACUS_AGENT_DEPLOYMENT_URL=
# ABACUS_API_KEY=


# --- ORATS (optional) -------------------------------------------------------

# ORATS API key for implied-volatility history. Unset falls back to stored IV.
# ORATS_API_KEY=
# ORATS_SYMBOL_OVERRIDES=


# --- External cron trigger --------------------------------------------------

# Shared secret for POST /api/analysis/trigger, /api/risk/evaluate, etc.
# Unset disables the endpoints that require it.
# CRON_API_KEY=


# --- Server ----------------------------------------------------------------

# HTTP listener — defaults to 127.0.0.1:3000.
# PORT=3000
# HOST=0.0.0.0
