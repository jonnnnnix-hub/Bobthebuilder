generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model universe {
  id        Int      @id @default(autoincrement())
  symbol    String   @unique @db.VarChar(20)
  name      String   @db.VarChar(200)
  sector    String?  @db.VarChar(100)
  active    Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  signals   signal[]
  market_bars market_bar[]

  @@index([active])
}

model signal {
  id                       Int      @id @default(autoincrement())
  symbol                   String   @db.VarChar(20)
  date                     DateTime @db.Date
  atm_iv                   Float?
  hv_10                    Float?
  hv_20                    Float?
  hv_60                    Float?
  vrp_20                   Float?
  vrp_percentile           Float?
  iv_z                     Float?
  iv_z_percentile          Float?
  iv_history_source        String?  @db.VarChar(30)
  rank                     Int?
  selected                 Boolean  @default(false)
  selection_reason         String?  @db.VarChar(100)
  composite_score          Float?
  composite_score_normalized Float?
  score_confidence         Float?
  confidence_low           Float?
  confidence_high          Float?
  score_version            String   @default("v2") @db.VarChar(20)
  category_scores          Json?
  run_id                   String   @db.VarChar(50)
  created_at               DateTime @default(now())

  universe_rel             universe? @relation(fields: [symbol], references: [symbol])
  analysis_run             analysis_run? @relation(fields: [run_id], references: [run_id])
  trades                   trade[]
  backtest_results         backtest_result[]
  agent_votes              agent_vote[]
  score_breakdowns         score_breakdown[]
  score_histories          score_history[]
  trade_decisions          trade_decision[]
  agent_debates            agent_debate[]
  agent_opinions           agent_opinion[]
  consensus_results        consensus_result[]

  @@unique([symbol, date, run_id])
  @@index([date])
  @@index([selected])
  @@index([run_id])
  @@index([composite_score_normalized])
}

model analysis_run {
  id                 Int      @id @default(autoincrement())
  run_id             String   @unique @db.VarChar(50)
  started_at         DateTime @default(now())
  completed_at       DateTime?
  symbols_analyzed   Int      @default(0)
  signals_generated  Int      @default(0)
  status             String   @default("running") @db.VarChar(20)
  errors             String?  @db.Text
  duration_ms        Int?
  trigger            String   @default("manual") @db.VarChar(20)

  signals            signal[]

  @@index([started_at])
  @@index([status])
}

model configuration {
  id         Int      @id @default(autoincrement())
  key        String   @unique @db.VarChar(100)
  value      String   @db.Text
  description String? @db.VarChar(500)
  updated_at DateTime @updatedAt
}

model market_bar {
  id            Int      @id @default(autoincrement())
  symbol        String   @db.VarChar(20)
  date          DateTime @db.Date
  open          Float
  high          Float
  low           Float
  close         Float
  volume        BigInt
  transactions  BigInt?
  source        String   @default("polygon_flat_file") @db.VarChar(50)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  universe_rel  universe? @relation(fields: [symbol], references: [symbol])

  @@unique([symbol, date])
  @@index([date])
  @@index([symbol, date])
}

model ingestion_run {
  id               Int      @id @default(autoincrement())
  provider         String   @db.VarChar(50)
  dataset          String   @db.VarChar(100)
  target_date      DateTime @db.Date
  trigger          String   @default("manual") @db.VarChar(20)
  status           String   @default("running") @db.VarChar(20)
  rows_considered  Int      @default(0)
  rows_ingested    Int      @default(0)
  rows_skipped     Int      @default(0)
  duration_ms      Int?
  errors           String?  @db.Text
  started_at       DateTime @default(now())
  completed_at     DateTime?

  @@index([provider, dataset, target_date])
  @@index([started_at])
  @@index([status])
}

model option_chain_snapshot {
  id                BigInt   @id @default(autoincrement())
  snapshot_date     DateTime @db.Date
  snapshot_ts       DateTime
  underlying_symbol String   @db.VarChar(20)
  option_symbol     String   @db.VarChar(40)
  expiration        DateTime @db.Date
  strike            Decimal  @db.Decimal(12, 4)
  option_type       String   @db.VarChar(4)
  bid               Decimal? @db.Decimal(12, 4)
  ask               Decimal? @db.Decimal(12, 4)
  mid               Decimal? @db.Decimal(12, 4)
  last              Decimal? @db.Decimal(12, 4)
  mark              Decimal? @db.Decimal(12, 4)
  volume            Int?
  open_interest     Int?
  implied_volatility Decimal? @db.Decimal(12, 6)
  delta             Decimal? @db.Decimal(12, 6)
  gamma             Decimal? @db.Decimal(12, 6)
  theta             Decimal? @db.Decimal(12, 6)
  vega              Decimal? @db.Decimal(12, 6)
  rho               Decimal? @db.Decimal(12, 6)
  source_primary    String   @db.VarChar(40)
  source_secondary  String?  @db.VarChar(40)
  freshness_tier    String   @default("intraday") @db.VarChar(20)
  quality_status    String   @default("valid") @db.VarChar(30)
  quality_flags     Json?
  raw_payload       Json?
  created_at        DateTime @default(now())

  @@unique([snapshot_ts, option_symbol, source_primary])
  @@index([underlying_symbol, snapshot_date])
  @@index([underlying_symbol, expiration, strike, option_type])
  @@index([quality_status, snapshot_date])
}

model score_breakdown {
  id              BigInt   @id @default(autoincrement())
  signal_id       Int
  category        String   @db.VarChar(40)
  sub_score_name  String   @db.VarChar(80)
  raw_value       Decimal? @db.Decimal(14, 6)
  scaled_score    Decimal? @db.Decimal(14, 6)
  max_possible    Decimal  @db.Decimal(14, 6)
  data_source     String?  @db.VarChar(60)
  is_null         Boolean  @default(false)
  metadata        Json?
  created_at      DateTime @default(now())

  signal_rel      signal   @relation(fields: [signal_id], references: [id], onDelete: Cascade)

  @@index([signal_id])
  @@index([category])
}

model score_history {
  id               BigInt   @id @default(autoincrement())
  signal_id        Int
  symbol           String   @db.VarChar(20)
  score_date       DateTime @db.Date
  run_id           String   @db.VarChar(50)
  composite_score  Decimal? @db.Decimal(14, 6)
  normalized_score Decimal? @db.Decimal(14, 6)
  confidence_score Decimal? @db.Decimal(14, 6)
  confidence_low   Decimal? @db.Decimal(14, 6)
  confidence_high  Decimal? @db.Decimal(14, 6)
  category_scores  Json?
  score_version    String   @default("v2") @db.VarChar(20)
  created_at       DateTime @default(now())

  signal_rel       signal   @relation(fields: [signal_id], references: [id], onDelete: Cascade)

  @@unique([signal_id])
  @@index([symbol, score_date])
  @@index([run_id])
}

model backtest_result {
  id                    BigInt   @id @default(autoincrement())
  backtest_run_id       String   @db.VarChar(80)
  signal_id             Int?
  trade_id              Int?
  symbol                String   @db.VarChar(20)
  strategy              String   @db.VarChar(40)
  entry_date            DateTime @db.Date
  exit_date             DateTime? @db.Date
  status                String   @db.VarChar(30)
  fill_policy_version   String   @db.VarChar(40)
  entry_fill_details    Json
  exit_fill_details     Json?
  legs                  Json
  fees                  Decimal? @db.Decimal(12, 4)
  slippage              Decimal? @db.Decimal(12, 4)
  gross_pnl             Decimal? @db.Decimal(14, 4)
  net_pnl               Decimal? @db.Decimal(14, 4)
  return_pct            Decimal? @db.Decimal(12, 6)
  max_drawdown_pct      Decimal? @db.Decimal(12, 6)
  quality_flags         Json?
  created_at            DateTime @default(now())

  signal_rel            signal?  @relation(fields: [signal_id], references: [id])
  trade_rel             trade?   @relation(fields: [trade_id], references: [id])
  loss_autopsies        loss_autopsy[]

  @@index([backtest_run_id])
  @@index([symbol, entry_date])
  @@index([status])
  @@index([signal_id])
  @@index([trade_id])
}

model agent_vote {
  id                 BigInt   @id @default(autoincrement())
  run_id             String   @db.VarChar(80)
  signal_id          Int?
  debate_id          BigInt?
  model_iteration_id BigInt?
  agent_name         String   @db.VarChar(80)
  agent_role         String?  @db.VarChar(80)
  round_number       Int
  vote               String   @db.VarChar(20)
  confidence_score   Decimal? @db.Decimal(6, 4)
  score              Decimal? @db.Decimal(10, 4)
  rationale          String?  @db.Text
  challenge_to       String?  @db.VarChar(80)
  transcript         Json?
  created_at         DateTime @default(now())

  signal_rel         signal?  @relation(fields: [signal_id], references: [id])
  debate_rel         agent_debate? @relation(fields: [debate_id], references: [id])
  model_iteration_rel model_iteration? @relation(fields: [model_iteration_id], references: [id])

  @@index([run_id, round_number])
  @@index([agent_name])
  @@index([signal_id])
  @@index([debate_id])
  @@index([model_iteration_id])
}

model agent_debate {
  id                     BigInt   @id @default(autoincrement())
  run_id                 String   @db.VarChar(80)
  signal_id              Int
  symbol                 String   @db.VarChar(20)
  status                 String   @default("running") @db.VarChar(30)
  consensus              String?  @db.VarChar(30)
  consensus_strength     String?  @db.VarChar(30)
  weighted_approval_pct  Decimal? @db.Decimal(8, 4)
  risk_vetoed            Boolean  @default(false)
  error_message          String?  @db.Text
  started_at             DateTime @default(now())
  completed_at           DateTime?
  created_at             DateTime @default(now())

  signal_rel             signal   @relation(fields: [signal_id], references: [id], onDelete: Cascade)
  opinions               agent_opinion[]
  transcripts            debate_transcript[]
  votes                  agent_vote[]
  consensus_result       consensus_result?

  @@index([signal_id])
  @@index([run_id])
  @@index([status, created_at])
  @@index([symbol, created_at])
}

model agent_opinion {
  id                BigInt   @id @default(autoincrement())
  debate_id         BigInt
  signal_id         Int
  run_id            String   @db.VarChar(80)
  agent_name        String   @db.VarChar(80)
  round_number      Int
  category_score    Decimal? @db.Decimal(10, 4)
  conviction        String   @db.VarChar(20)
  thesis            String   @db.Text
  key_risk          String?  @db.Text
  vote              String   @db.VarChar(20)
  confidence_score  Decimal? @db.Decimal(6, 4)
  challenge_payload Json?
  response_payload  Json?
  prompt_version    String?  @db.VarChar(20)
  metadata          Json?
  created_at        DateTime @default(now())

  debate_rel        agent_debate @relation(fields: [debate_id], references: [id], onDelete: Cascade)
  signal_rel        signal       @relation(fields: [signal_id], references: [id], onDelete: Cascade)

  @@index([debate_id, round_number])
  @@index([signal_id])
  @@index([agent_name])
}

model debate_transcript {
  id           BigInt   @id @default(autoincrement())
  debate_id    BigInt
  round_number Int
  transcript   Json
  created_at   DateTime @default(now())

  debate_rel   agent_debate @relation(fields: [debate_id], references: [id], onDelete: Cascade)

  @@unique([debate_id, round_number])
  @@index([debate_id])
}

model consensus_result {
  id                         BigInt   @id @default(autoincrement())
  debate_id                  BigInt   @unique
  signal_id                  Int
  symbol                     String   @db.VarChar(20)
  final_decision             String   @db.VarChar(30)
  consensus_strength         String   @db.VarChar(30)
  weighted_approval_pct      Decimal? @db.Decimal(8, 4)
  confidence_adjusted_score  Decimal? @db.Decimal(14, 6)
  risk_vetoed                Boolean  @default(false)
  votes                      Json
  key_thesis                 String?  @db.Text
  key_risk                   String?  @db.Text
  dissenting_views           Json?
  created_at                 DateTime @default(now())

  debate_rel                 agent_debate @relation(fields: [debate_id], references: [id], onDelete: Cascade)
  signal_rel                 signal       @relation(fields: [signal_id], references: [id], onDelete: Cascade)

  @@index([signal_id])
  @@index([symbol, created_at])
  @@index([final_decision])
}
model loss_autopsy {
  id                    BigInt   @id @default(autoincrement())
  backtest_result_id    BigInt?
  model_iteration_id    BigInt?
  symbol                String   @db.VarChar(20)
  trade_date            DateTime @db.Date
  root_cause            String   @db.VarChar(120)
  severity              String   @default("medium") @db.VarChar(20)
  hypothesis            String?  @db.Text
  evidence              Json?
  proposed_actions      Json?
  confidence_score      Decimal? @db.Decimal(6, 4)
  reviewed_by           String?  @db.VarChar(80)
  created_at            DateTime @default(now())

  backtest_result_rel   backtest_result? @relation(fields: [backtest_result_id], references: [id])
  model_iteration_rel   model_iteration? @relation(fields: [model_iteration_id], references: [id])

  @@index([symbol, trade_date])
  @@index([root_cause])
  @@index([backtest_result_id])
  @@index([model_iteration_id])
}

model model_iteration {
  id                      BigInt   @id @default(autoincrement())
  iteration_key           String   @unique @db.VarChar(80)
  parent_iteration_key    String?  @db.VarChar(80)
  model_version           String   @db.VarChar(80)
  status                  String   @default("draft") @db.VarChar(30)
  objective               String?  @db.VarChar(120)
  parameter_snapshot      Json
  parameter_diff          Json?
  in_sample_metrics       Json?
  out_of_sample_metrics   Json?
  proposed_by             String   @default("system") @db.VarChar(40)
  approved_by             String?  @db.VarChar(80)
  approved_at             DateTime?
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  agent_votes             agent_vote[]
  loss_autopsies          loss_autopsy[]

  @@index([status, created_at])
  @@index([model_version])
}

model fill_policy_config {
  id                        BigInt   @id @default(autoincrement())
  policy_name               String   @unique @db.VarChar(80)
  version                   String   @db.VarChar(40)
  is_default                Boolean  @default(false)
  slippage_bps              Decimal  @default(0) @db.Decimal(10, 4)
  commission_per_contract   Decimal  @default(0) @db.Decimal(10, 4)
  impact_enabled            Boolean  @default(true)
  impact_coefficient        Decimal  @default(0) @db.Decimal(10, 6)
  impact_exponent           Decimal  @default(1) @db.Decimal(10, 6)
  spread_participation_rate Decimal  @default(0.5) @db.Decimal(10, 6)
  min_fill_fraction         Decimal  @default(1) @db.Decimal(10, 6)
  notes                     String?  @db.Text
  created_at                DateTime @default(now())
  updated_at                DateTime @updatedAt

  @@unique([policy_name, version])
  @@index([is_default])
}

model trade {
  id           Int       @id @default(autoincrement())
  signal_id    Int?
  symbol       String    @db.VarChar(20)
  strategy     String    @db.VarChar(30)
  status       String    @default("pending") @db.VarChar(20)
  direction    String    @default("sell") @db.VarChar(10)
  opened_at    DateTime?
  closed_at    DateTime?
  entry_credit Float?
  exit_debit   Float?
  pnl          Float?
  pnl_pct      Float?
  contracts    Int       @default(1)
  notes        String?   @db.Text
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  signal_rel   signal?   @relation(fields: [signal_id], references: [id])
  legs         trade_leg[]
  snapshots    position_snapshot[]
  risk_checks  risk_check[]
  backtest_results backtest_result[]

  @@index([symbol])
  @@index([status])
  @@index([signal_id])
}

model trade_leg {
  id           Int      @id @default(autoincrement())
  trade_id     Int
  option_type  String   @db.VarChar(10)
  strike       Float
  expiration   DateTime @db.Date
  side         String   @db.VarChar(10)
  quantity     Int
  entry_price  Float?
  exit_price   Float?
  iv_at_entry  Float?
  delta_at_entry Float?
  created_at   DateTime @default(now())

  trade_rel    trade    @relation(fields: [trade_id], references: [id])

  @@index([trade_id])
}

model position_snapshot {
  id               Int      @id @default(autoincrement())
  trade_id         Int
  snapshot_date    DateTime @db.Date
  underlying_price Float
  mark_value       Float
  delta            Float?
  theta            Float?
  vega             Float?
  gamma            Float?
  days_to_expiry   Int
  pnl_unrealized   Float?
  created_at       DateTime @default(now())

  trade_rel        trade    @relation(fields: [trade_id], references: [id])

  @@index([trade_id])
  @@index([snapshot_date])
}

model risk_check {
  id         Int      @id @default(autoincrement())
  trade_id   Int?
  check_type String   @db.VarChar(50)
  status     String   @db.VarChar(20)
  value      Float?
  threshold  Float?
  message    String?  @db.VarChar(500)
  created_at DateTime @default(now())

  trade_rel  trade?   @relation(fields: [trade_id], references: [id])

  @@index([trade_id])
  @@index([check_type])
}

model alpaca_account {
  id            BigInt   @id @default(autoincrement())
  account_id    String   @unique @db.VarChar(80)
  status        String   @db.VarChar(30)
  currency      String   @default("USD") @db.VarChar(10)
  equity        Decimal? @db.Decimal(16, 4)
  cash          Decimal? @db.Decimal(16, 4)
  buying_power  Decimal? @db.Decimal(16, 4)
  daytrade_count Int? 
  raw_payload   Json?
  synced_at     DateTime @default(now())
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([synced_at])
}

model trade_decision {
  id                      BigInt   @id @default(autoincrement())
  signal_id               Int?
  symbol                  String   @db.VarChar(20)
  composite_score         Decimal? @db.Decimal(14, 6)
  score_confidence        Decimal? @db.Decimal(14, 6)
  market_regime           String?  @db.VarChar(40)
  volatility_environment  String?  @db.VarChar(40)
  selected_strategy       String   @db.VarChar(40)
  strategy_scoring        Json
  strike_selection        Json
  expiration_selection    Json
  position_size_usd       Decimal  @db.Decimal(14, 4)
  position_contracts      Int
  risk_state              String   @default("approved") @db.VarChar(30)
  rationale               Json?
  created_at              DateTime @default(now())

  signal_rel              signal? @relation(fields: [signal_id], references: [id])
  alpaca_orders           alpaca_order[]

  @@index([symbol, created_at])
  @@index([risk_state])
  @@index([signal_id])
}

model alpaca_order {
  id                  BigInt   @id @default(autoincrement())
  trade_decision_id   BigInt?
  alpaca_order_id     String?  @unique @db.VarChar(120)
  client_order_id     String?  @db.VarChar(120)
  symbol              String   @db.VarChar(40)
  side                String   @db.VarChar(10)
  order_type          String   @db.VarChar(20)
  quantity            Decimal? @db.Decimal(14, 4)
  limit_price         Decimal? @db.Decimal(14, 4)
  stop_price          Decimal? @db.Decimal(14, 4)
  status              String   @db.VarChar(30)
  filled_avg_price    Decimal? @db.Decimal(14, 4)
  filled_quantity     Decimal? @db.Decimal(14, 4)
  submitted_at        DateTime?
  filled_at           DateTime?
  request_payload     Json?
  response_payload    Json?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  trade_decision_rel  trade_decision? @relation(fields: [trade_decision_id], references: [id])

  @@index([symbol, created_at])
  @@index([status])
  @@index([trade_decision_id])
}

model position_monitoring {
  id                     BigInt   @id @default(autoincrement())
  alpaca_position_id     String?  @db.VarChar(120)
  symbol                 String   @db.VarChar(20)
  strategy               String?  @db.VarChar(40)
  quantity               Decimal? @db.Decimal(14, 4)
  avg_entry_price        Decimal? @db.Decimal(14, 4)
  current_price          Decimal? @db.Decimal(14, 4)
  market_value           Decimal? @db.Decimal(16, 4)
  unrealized_pl          Decimal? @db.Decimal(16, 4)
  unrealized_pl_pct      Decimal? @db.Decimal(12, 6)
  realized_pl            Decimal? @db.Decimal(16, 4)
  delta                  Decimal? @db.Decimal(14, 6)
  gamma                  Decimal? @db.Decimal(14, 6)
  theta                  Decimal? @db.Decimal(14, 6)
  vega                   Decimal? @db.Decimal(14, 6)
  dte_remaining          Int?
  exit_criteria_status   Json?
  last_synced_at         DateTime @default(now())
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  exit_signals           exit_signal[]

  @@index([symbol, last_synced_at])
  @@index([alpaca_position_id])
}

model exit_signal {
  id                      BigInt   @id @default(autoincrement())
  position_monitoring_id  BigInt
  trigger_type            String   @db.VarChar(40)
  trigger_value           Decimal? @db.Decimal(14, 6)
  threshold_value         Decimal? @db.Decimal(14, 6)
  action                  String   @default("exit") @db.VarChar(20)
  rationale               String?  @db.Text
  executed                Boolean  @default(false)
  executed_at             DateTime?
  created_at              DateTime @default(now())

  position_monitoring_rel position_monitoring @relation(fields: [position_monitoring_id], references: [id], onDelete: Cascade)

  @@index([position_monitoring_id, created_at])
  @@index([executed])
}

model risk_metrics {
  id                        BigInt   @id @default(autoincrement())
  portfolio_value           Decimal? @db.Decimal(16, 4)
  var_95                    Decimal? @db.Decimal(16, 4)
  max_drawdown_pct          Decimal? @db.Decimal(12, 6)
  portfolio_heat_pct        Decimal? @db.Decimal(12, 6)
  max_symbol_concentration  Decimal? @db.Decimal(12, 6)
  max_sector_concentration  Decimal? @db.Decimal(12, 6)
  portfolio_delta           Decimal? @db.Decimal(14, 6)
  portfolio_gamma           Decimal? @db.Decimal(14, 6)
  portfolio_theta           Decimal? @db.Decimal(14, 6)
  portfolio_vega            Decimal? @db.Decimal(14, 6)
  liquidity_score           Decimal? @db.Decimal(12, 6)
  market_regime             String?  @db.VarChar(40)
  metrics_payload           Json?
  created_at                DateTime @default(now())

  @@index([created_at])
}

model trading_log {
  id           BigInt   @id @default(autoincrement())
  level        String   @db.VarChar(12)
  event_type   String   @db.VarChar(40)
  symbol       String?  @db.VarChar(20)
  message      String   @db.Text
  payload      Json?
  created_at   DateTime @default(now())

  @@index([created_at])
  @@index([event_type])
}